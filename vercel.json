{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "redirects": [
    {
      "source": "/(.*)",
      "has": [{ "type": "host", "value": "dataact.transload.io" }],
      "destination": "https://transload.io/dataact",
      "permanent": true
    },
    {
      "source": "/(.*)",
      "has": [{ "type": "host", "value": "dataact.trans-load.de" }],
      "destination": "https://transload.io/dataact",
      "permanent": true
    }
  ]
}
